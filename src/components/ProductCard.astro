---
interface Props {
  product: {
    id: string;
    slug: string;
    name: string;
    price: number;
    priceOnRequest?: boolean;
    condition: string;
    availability: string;
    image: string;
  };
}
const { product } = Astro.props;
const stockLabel = { in: 'В наявності', order: 'Під замовлення', out: 'Немає в наявності' }[product.availability] || 'Уточнюйте';
---

<a href={`/catalog/${product.slug}/`} class="card ticket">
  <span class="ticket-no">№{product.id.padStart(4, '0')}</span>
  <div class="card-image">
    <img src={product.image} alt={product.name} loading="lazy" />
    {product.condition === 'used' && <span class="tag tag-used">Б/У</span>}
    <span class:list={['cart-badge', product.availability]} title={stockLabel} aria-hidden="true">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.6 13.4a2 2 0 0 0 2 1.6h9.8a2 2 0 0 0 2-1.6L23 6H6"></path>
      </svg>
    </span>
  </div>
  <div class="card-body">
    <h3 class="card-title">{product.name}</h3>
    <div class="card-bottom">
      {product.priceOnRequest
        ? <span class="card-price card-price-request">Ціна за запитом</span>
        : <span class="card-price">{product.price} ₴</span>}
      <span class:list={['stock', product.availability]}>{stockLabel}</span>
    </div>
    {product.availability !== 'out' && (
      <button
        type="button"
        class="btn btn-ghost card-add"
        data-add-to-cart
        data-slug={product.slug}
        data-name={product.name}
        data-price={product.price}
        data-price-on-request={String(!!product.priceOnRequest)}
        data-image={product.image}
        data-availability={product.availability}
      >
        У кошик
      </button>
    )}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .ticket-no {
    position: absolute;
    top: 10px;
    left: 12px;
    z-index: 2;
    background: rgba(20,20,20,0.8);
    padding: 2px 6px;
    border-radius: var(--radius);
    font-size: 11px;
  }
  .card-image {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .card-image img { width: 100%; height: 100%; object-fit: cover; }
  .tag {
    position: absolute;
    bottom: 8px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 7px;
    border-radius: var(--radius);
    text-transform: uppercase;
  }
  .tag-used { background: var(--copper); color: #FFFFFF; }
  .cart-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    box-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  .cart-badge.in { background: var(--ok); }
  .cart-badge.order { background: #57544C; }
  .cart-badge.out { background: var(--out); }
  .card-body { padding: 12px 14px 14px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .card-title {
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    margin: 0;
    color: var(--text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-bottom { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .card-price { font-family: var(--font-mono); font-size: 15px; color: var(--accent); }
  .card-price-request { font-size: 12.5px; }
  .stock { font-size: 10.5px; font-family: var(--font-mono); white-space: nowrap; }
  .stock.in { color: var(--ok); }
  .stock.order { color: var(--text-dim); }
  .stock.out { color: var(--out); }
  .card-add {
    width: 100%;
    justify-content: center;
    padding: 8px 12px;
    font-size: 12px;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement)?.closest('[data-add-to-cart]') as HTMLElement | null;
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const w = window as any;
    if (!w.MelonCart) return;

    w.MelonCart.add({
      slug: btn.dataset.slug,
      name: btn.dataset.name,
      price: Number(btn.dataset.price) || 0,
      priceOnRequest: btn.dataset.priceOnRequest === 'true',
      image: btn.dataset.image,
      availability: btn.dataset.availability,
    }, 1);

    const original = btn.textContent;
    btn.textContent = 'Додано ✓';
    btn.setAttribute('disabled', 'true');
    setTimeout(() => {
      btn.textContent = original;
      btn.removeAttribute('disabled');
    }, 1200);
  });
</script>
