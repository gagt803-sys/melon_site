---
import BaseLayout from '../../layouts/BaseLayout.astro';
import products from '../../data/products.json';
import categories from '../../data/categories.json';
import site from '../../data/site.json';

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;
const categoryLabel = categories.find((c) => c.id === product.category)?.label ?? '';
---

<BaseLayout
  title={`${product.name} — ${site.name}`}
  description={product.description}
>
  <section class="section">
    <div class="container product-layout">
      <div class="product-image ticket">
        <span class="ticket-no">№{product.id.padStart(3, '0')}</span>
        <img src={product.image} alt={product.name} />
        {product.condition === 'used' && <span class="tag tag-used">Б/У</span>}
        <span class:list={['cart-badge', product.availability]} aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.6 13.4a2 2 0 0 0 2 1.6h9.8a2 2 0 0 0 2-1.6L23 6H6"></path>
          </svg>
        </span>
      </div>

      <div class="product-info">
        <a href="/catalog/" class="back-link">← Усі товари</a>
        <span class="category-label">{categoryLabel}</span>
        <h1>{product.name}</h1>
        <div class="price-row">
          {product.priceOnRequest
            ? <span class="price price-request">Ціна за запитом</span>
            : <span class="price">{product.price} ₴</span>}
          <span class:list={['stock', product.availability]}>
            {({ in: 'В наявності', order: 'Під замовлення', out: 'Немає в наявності' })[product.availability] || 'Уточнюйте'}
          </span>
        </div>

        <p class="description">{product.description}</p>

        <dl class="specs">
          <div><dt>Стан</dt><dd>{product.condition === 'new' ? 'Нове' : 'Б/У'}</dd></div>
          {product.brand && <div><dt>Виробник</dt><dd>{product.brand}</dd></div>}
          {product.warranty && <div><dt>Гарантія</dt><dd>{product.warranty}</dd></div>}
        </dl>

        {product.availability !== 'out' ? (
          <div class="buy-box">
            <div class="qty-row">
              <span class="qty-label">Кількість</span>
              <div class="qty-stepper">
                <button type="button" id="qty-minus" aria-label="Менше">−</button>
                <input type="number" id="qty-input" value="1" min="1" max="99" inputmode="numeric" />
                <button type="button" id="qty-plus" aria-label="Більше">+</button>
              </div>
            </div>
            <div class="actions">
              <button type="button" class="btn btn-primary" id="buy-now-btn">Оформити покупку</button>
              <button type="button" class="btn btn-ghost" id="add-to-cart-btn">Додати в кошик</button>
            </div>
            <p class="buy-hint">Самовивіз з магазину, безкоштовна доставка по місту або Нова пошта — спосіб оберете на сторінці кошика.</p>
          </div>
        ) : (
          <p class="buy-hint">Цього товару зараз немає в наявності — зателефонуйте, підкажемо аналог або термін надходження.</p>
        )}

        <div class="actions">
          <a href={`tel:${site.phone.replace(/\s+/g, '')}`} class="btn btn-ghost">
            Подзвонити: {site.phoneDisplay}
          </a>
          <a href="/contacts/" class="btn btn-ghost">Як забрати</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding: 44px 0 70px; }
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .product-image {
    position: relative;
    overflow: hidden;
  }
  .product-image img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .tag {
    position: absolute;
    bottom: 12px;
    left: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 8px;
    border-radius: var(--radius);
    text-transform: uppercase;
    background: var(--copper);
    color: #FFFFFF;
  }
  .cart-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    box-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  .cart-badge.in { background: var(--ok); }
  .cart-badge.order { background: #57544C; }
  .cart-badge.out { background: var(--out); }
  .back-link { font-size: 13px; color: var(--text-dim); display: inline-block; margin-bottom: 18px; }
  .back-link:hover { color: var(--accent); }
  .category-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }
  .product-info h1 { font-size: 26px; margin-bottom: 14px; }
  .price-row { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
  .price { font-family: var(--font-mono); font-size: 26px; color: var(--accent); }
  .price-request { font-size: 18px; }
  .stock { font-family: var(--font-mono); font-size: 13px; }
  .stock.in { color: var(--ok); }
  .stock.order { color: var(--text-dim); }
  .stock.out { color: var(--out); }
  .description { color: var(--text-dim); margin-bottom: 24px; }

  .specs {
    display: grid;
    gap: 10px;
    margin: 0 0 28px;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .specs > div { display: flex; justify-content: space-between; font-size: 14px; }
  .specs dt { color: var(--text-dim); margin: 0; }
  .specs dd { margin: 0; font-family: var(--font-mono); }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }

  .buy-box {
    padding: 18px;
    margin-bottom: 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .qty-row { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .qty-label { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.04em; }
  .qty-stepper { display: inline-flex; align-items: center; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .qty-stepper button {
    width: 34px; height: 34px;
    background: var(--bg);
    color: var(--text);
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-family: var(--font-mono);
  }
  .qty-stepper button:hover { color: var(--accent); }
  .qty-stepper input {
    width: 46px; height: 34px;
    text-align: center;
    background: var(--bg);
    color: var(--text);
    border: none;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 14px;
  }
  .buy-hint { color: var(--text-dim); font-size: 12.5px; margin: 0; }

  @media (max-width: 800px) {
    .product-layout { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{
  slug: product.slug,
  name: product.name,
  price: product.price,
  priceOnRequest: !!product.priceOnRequest,
  image: product.image,
  availability: product.availability,
}}>
  const qtyInput = document.getElementById('qty-input');
  const minusBtn = document.getElementById('qty-minus');
  const plusBtn = document.getElementById('qty-plus');
  const addBtn = document.getElementById('add-to-cart-btn');
  const buyBtn = document.getElementById('buy-now-btn');

  function getQty() {
    const v = parseInt(qtyInput?.value, 10);
    return Number.isFinite(v) && v > 0 ? Math.min(99, v) : 1;
  }

  minusBtn?.addEventListener('click', () => {
    if (qtyInput) qtyInput.value = String(Math.max(1, getQty() - 1));
  });
  plusBtn?.addEventListener('click', () => {
    if (qtyInput) qtyInput.value = String(Math.min(99, getQty() + 1));
  });

  function addCurrentToCart() {
    if (!window.MelonCart) return;
    window.MelonCart.add({ slug, name, price, priceOnRequest, image, availability }, getQty());
  }

  addBtn?.addEventListener('click', () => {
    addCurrentToCart();
    const original = addBtn.textContent;
    addBtn.textContent = 'Додано ✓';
    setTimeout(() => { addBtn.textContent = original; }, 1200);
  });

  buyBtn?.addEventListener('click', () => {
    addCurrentToCart();
    window.location.href = '/cart/';
  });
</script>
